generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  customer
  worker
  admin
}

enum UserStatus {
  active
  inactive
}

enum WorkerStatus {
  available
  offline
  busy
  on_the_way
  working
}

enum OrderStatus {
  created
  waiting_confirmation
  finding_worker
  worker_assigned
  worker_on_the_way
  arrived
  working
  completed
  waiting_rating
  finished
  cancelled
}

enum PaymentStatus {
  unpaid
  paid
  refunded
  failed
}

enum DiscountType {
  percentage
  fixed
}

enum BannerType {
  main_banner
  side_banner
}

enum BannerMode {
  image
  template
}

model User {
  id              String           @id @default(cuid())
  name            String
  email           String           @unique
  phone           String?          @unique
  passwordHash    String           @map("password_hash")
  role            UserRole
  avatarUrl       String?          @map("avatar_url")
  status          UserStatus       @default(active)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  customerProfile CustomerProfile?
  workerProfile   WorkerProfile?
  addresses       Address[]
  customerOrders  Order[]          @relation("CustomerOrders")
  workerOrders    Order[]          @relation("WorkerOrders")
  statusLogs      OrderStatusLog[]
  reviewsGiven    Review[]         @relation("CustomerReviews")
  reviewsReceived Review[]         @relation("WorkerReviews")
  notifications   Notification[]

  @@map("users")
}

model CustomerProfile {
  id               String    @id @default(cuid())
  userId           String    @unique @map("user_id")
  defaultAddressId String?   @map("default_address_id")
  notes            String?   @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultAddress   Address?  @relation(fields: [defaultAddressId], references: [id], onDelete: SetNull)

  @@map("customer_profiles")
}

model WorkerProfile {
  id            String       @id @default(cuid())
  userId        String       @unique @map("user_id")
  skills        Json
  status        WorkerStatus @default(available)
  rating        Decimal      @default(4.8) @db.Decimal(3, 2)
  completedJobs Int          @default(0) @map("completed_jobs")
  earningsTotal Decimal      @default(0) @map("earnings_total") @db.Decimal(12, 2)
  earningsToday Decimal      @default(0) @map("earnings_today") @db.Decimal(12, 2)
  verifiedAt    DateTime?    @map("verified_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("worker_profiles")
}

model Address {
  id               String            @id @default(cuid())
  userId           String            @map("user_id")
  label            String
  recipientName    String?           @map("recipient_name")
  phone            String?
  fullAddress      String            @map("full_address") @db.Text
  city             String?
  district         String?
  postalCode       String?           @map("postal_code")
  notes            String?           @db.Text
  latitude         Decimal?          @db.Decimal(10, 7)
  longitude        Decimal?          @db.Decimal(10, 7)
  isDefault        Boolean           @default(false) @map("is_default")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerProfiles CustomerProfile[]
  orders           Order[]

  @@index([userId])
  @@map("addresses")
}

model Service {
  id            String           @id @default(cuid())
  name          String
  slug          String           @unique
  category      String
  description   String           @db.Text
  icon          String?
  imageUrl      String?          @map("image_url")
  startingPrice Decimal          @map("starting_price") @db.Decimal(12, 2)
  duration      String
  rating        Decimal          @default(4.8) @db.Decimal(3, 2)
  totalReviews  Int              @default(0) @map("total_reviews")
  isActive      Boolean          @default(true) @map("is_active")
  sortOrder     Int              @default(1) @map("sort_order")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  packages      ServicePackage[]
  addOns        AddOn[]
  orders        Order[]

  @@map("services")
}

model ServicePackage {
  id          String   @id @default(cuid())
  serviceId   String   @map("service_id")
  name        String
  description String   @db.Text
  price       Decimal  @db.Decimal(12, 2)
  duration    String
  includes    Json
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(1) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@index([serviceId])
  @@map("service_packages")
}

model AddOn {
  id          String       @id @default(cuid())
  serviceId   String       @map("service_id")
  name        String
  description String?      @db.Text
  price       Decimal      @db.Decimal(12, 2)
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  service     Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  orderAddOns OrderAddOn[]

  @@index([serviceId])
  @@map("add_ons")
}

model Order {
  id             String           @id @default(cuid())
  orderCode      String           @unique @map("order_code")
  customerId     String           @map("customer_id")
  workerId       String?          @map("worker_id")
  serviceId      String           @map("service_id")
  packageId      String           @map("package_id")
  addressId      String           @map("address_id")
  status         OrderStatus      @default(created)
  bookingDate    DateTime         @map("booking_date") @db.Date
  bookingTime    String           @map("booking_time")
  paymentMethod  String           @map("payment_method")
  paymentStatus  PaymentStatus    @default(unpaid) @map("payment_status")
  subtotal       Decimal          @db.Decimal(12, 2)
  discount       Decimal          @default(0) @db.Decimal(12, 2)
  totalPrice     Decimal          @map("total_price") @db.Decimal(12, 2)
  promoCode      String?          @map("promo_code")
  customerNotes  String?          @map("customer_notes") @db.Text
  adminNotes     String?          @map("admin_notes") @db.Text
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  customer       User             @relation("CustomerOrders", fields: [customerId], references: [id])
  worker         User?            @relation("WorkerOrders", fields: [workerId], references: [id], onDelete: SetNull)
  service        Service          @relation(fields: [serviceId], references: [id])
  package        ServicePackage   @relation(fields: [packageId], references: [id])
  address        Address          @relation(fields: [addressId], references: [id])
  addOns         OrderAddOn[]
  statusLogs     OrderStatusLog[]
  payments       Payment[]
  review         Review?

  @@index([customerId])
  @@index([workerId])
  @@index([status])
  @@map("orders")
}

model OrderAddOn {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  addOnId   String?  @map("add_on_id")
  name      String
  price     Decimal  @db.Decimal(12, 2)
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  addOn     AddOn?   @relation(fields: [addOnId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("order_add_ons")
}

model OrderStatusLog {
  id              String      @id @default(cuid())
  orderId          String      @map("order_id")
  status           OrderStatus
  note             String?     @db.Text
  changedByUserId  String?     @map("changed_by_user_id")
  createdAt        DateTime    @default(now()) @map("created_at")
  order            Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  changedBy        User?       @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("order_status_logs")
}

model Payment {
  id              String        @id @default(cuid())
  orderId          String        @map("order_id")
  paymentMethod    String        @map("payment_method")
  paymentStatus    PaymentStatus @default(unpaid) @map("payment_status")
  amount           Decimal       @db.Decimal(12, 2)
  paidAt           DateTime?     @map("paid_at")
  referenceNumber  String?       @map("reference_number")
  proofImageUrl    String?       @map("proof_image_url")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")
  order            Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("payments")
}

model Review {
  id         String   @id @default(cuid())
  orderId    String   @unique @map("order_id")
  customerId String   @map("customer_id")
  workerId   String   @map("worker_id")
  rating     Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer   User     @relation("CustomerReviews", fields: [customerId], references: [id])
  worker     User     @relation("WorkerReviews", fields: [workerId], references: [id])

  @@map("reviews")
}

model Promo {
  id            String       @id @default(cuid())
  code          String       @unique
  title         String
  description   String       @db.Text
  discountType  DiscountType @map("discount_type")
  discountValue Decimal      @map("discount_value") @db.Decimal(12, 2)
  maxDiscount   Decimal?     @map("max_discount") @db.Decimal(12, 2)
  minOrder      Decimal      @default(0) @map("min_order") @db.Decimal(12, 2)
  startDate     DateTime?    @map("start_date")
  endDate       DateTime?    @map("end_date")
  usageLimit    Int?         @map("usage_limit")
  usedCount     Int          @default(0) @map("used_count")
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@map("promos")
}

model Banner {
  id               String     @id @default(cuid())
  internalTitle    String     @map("internal_title")
  bannerType       BannerType @map("banner_type")
  mode             BannerMode
  isActive         Boolean    @default(true) @map("is_active")
  sortOrder        Int        @default(1) @map("sort_order")
  startDate        DateTime?  @map("start_date")
  endDate          DateTime?  @map("end_date")
  desktopImageUrl  String?    @map("desktop_image_url")
  mobileImageUrl   String?    @map("mobile_image_url")
  altText          String?    @map("alt_text")
  ctaLabel         String?    @map("cta_label")
  ctaLink          String?    @map("cta_link")
  badgeText        String?    @map("badge_text")
  headline         String?
  description      String?    @db.Text
  promoCode        String?    @map("promo_code")
  helperText       String?    @map("helper_text")
  icon             String?
  accentStyle      String?    @map("accent_style")
  templateVariant  String?    @map("template_variant")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  @@index([bannerType, isActive])
  @@map("banners")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String
  message   String   @db.Text
  type      String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}
